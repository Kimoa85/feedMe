# Copy this file to .env for local development
# Never commit .env to git

DATABASE_URL=postgresql://user:password@localhost:5432/feedme
SESSION_SECRET=change-this-to-something-random-and-long
BASE_URL=http://localhost:3000

# Optional — only needed if you want "forgot code" emails to work
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
NODE_ENV=development
