<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>feedMe — My Dashboard 🍰</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Pacifico&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧁</text></svg>">
</head>
<body>

  <header class="topbar">
    <div class="topbar-left">
      <span class="brand brand-sm">feedMe</span>
    </div>
    <div class="topbar-right">
      <span class="welcome-text">Hi, <strong><%= user.display_name %></strong> ✨</span>
      <a href="/logout" class="btn btn-ghost btn-sm">Logout</a>
    </div>
  </header>

  <main class="dashboard-main">

    <!-- How it works -->
    <section class="card how-it-works">
      <h2 class="section-title">🍰 How feedMe works</h2>
      <ol class="steps">
        <li>
          <span class="step-num">1</span>
          <span>Click <strong>Generate Feedback Link</strong> below to create a unique, one-time link.</span>
        </li>
        <li>
          <span class="step-num">2</span>
          <span>Copy the link and share it with someone you'd like feedback from.</span>
        </li>
        <li>
          <span class="step-num">3</span>
          <span>They fill in the form and submit — it appears in your dashboard here.</span>
        </li>
        <li>
          <span class="step-num">4</span>
          <span>Each link works once. Need more? Just generate another! 🌸</span>
        </li>
      </ol>
    </section>

    <!-- Generate link -->
    <section class="card generate-section">
      <h2 class="section-title">✨ Get feedback from someone new</h2>

      <% if (newToken) { %>
        <div class="new-link-box">
          <p class="new-link-label">🎉 Your link is ready! Copy it and share:</p>
          <div class="link-row">
            <input type="text" id="generatedLink" value="<%= baseUrl %>/f/<%= newToken %>" readonly>
            <button class="btn btn-copy" id="copyBtn">Copy 🌸</button>
          </div>
          <p class="link-hint">💡 This link can only be used once. Generate a new one for each person.</p>
        </div>
      <% } %>

      <form action="/generate-link" method="POST">
        <button type="submit" class="btn btn-primary">🌷 Generate Feedback Link</button>
      </form>
    </section>

    <!-- Feedback received -->
    <section class="feedback-inbox">
      <h2 class="section-title">💌 Feedback I've received
        <span class="count-badge"><%= submissions.length %></span>
      </h2>

      <% if (submissions.length === 0) { %>
        <div class="card empty-state">
          <div class="empty-icon">🌱</div>
          <p>No feedback yet — share your link to get started!</p>
        </div>

      <% } else { %>

        <%
          const lastDate = submissions.reduce((latest, s) => {
            const d = new Date(s.submitted_at);
            return d > latest ? d : latest;
          }, new Date(0));
        %>
        <div class="feedback-summary-bar">
          <strong><%= submissions.length %></strong>&nbsp;<%= submissions.length === 1 ? 'response' : 'responses' %>
          <span class="summary-divider">·</span>
          Last received <strong><%= lastDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></strong>
        </div>

        <%
          const questions = [
            { key: 'what_working_well',     icon: '✨', label: "What's working well" },
            { key: 'strengths',             icon: '💪', label: 'Strengths to lean into' },
            { key: 'growth_opportunities',  icon: '🌱', label: 'Growth opportunities' },
            { key: 'actionable_suggestions',icon: '🔧', label: 'Actionable suggestions' },
            { key: 'collaboration',         icon: '🤝', label: 'Collaboration & team experience' },
            { key: 'looking_ahead',         icon: '🚀', label: 'Looking ahead' },
          ];
        %>

        <div class="feedback-report">
          <% questions.forEach(q => { %>
            <div class="report-section card">
              <h3 class="report-section-title">
                <span class="report-icon"><%= q.icon %></span><%= q.label %>
              </h3>
              <div class="responses-list">
                <% submissions.forEach(sub => { %>
                  <% if (sub[q.key]) { %>
                    <div class="response-item">
                      <p class="response-text"><%= sub[q.key] %></p>
                      <div class="response-meta">
                        <span class="responder-tag"><%= sub.submitter_name || 'Anonymous' %></span>
                        <span class="response-date"><%= new Date(sub.submitted_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                      </div>
                    </div>
                  <% } %>
                <% }) %>
              </div>
            </div>
          <% }) %>

          <% const anythingElseResponses = submissions.filter(s => s.anything_else); %>
          <% if (anythingElseResponses.length > 0) { %>
            <div class="report-section card">
              <h3 class="report-section-title">
                <span class="report-icon">💬</span>Anything else
              </h3>
              <div class="responses-list">
                <% anythingElseResponses.forEach(sub => { %>
                  <div class="response-item">
                    <p class="response-text"><%= sub.anything_else %></p>
                    <div class="response-meta">
                      <span class="responder-tag"><%= sub.submitter_name || 'Anonymous' %></span>
                      <span class="response-date"><%= new Date(sub.submitted_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>

        <%
          const supportMap = new Map();
          submissions.forEach(sub => {
            if (sub.support_offers && sub.support_offers.length > 0) {
              sub.support_offers.forEach(offer => {
                if (!supportMap.has(offer)) supportMap.set(offer, []);
                supportMap.get(offer).push(sub.submitter_name || 'Anonymous');
              });
            }
          });
          const supportOthers = submissions.filter(s => s.support_other);
          const hasSupportData = supportMap.size > 0 || supportOthers.length > 0;
        %>

        <% if (hasSupportData) { %>
          <div class="card support-hub">
            <h3 class="report-section-title">
              <span class="report-icon">🎁</span>Support on offer
            </h3>
            <p class="support-hub-intro">Your colleagues are ready to help — here's what they've offered.</p>

            <% if (supportMap.size > 0) { %>
              <div class="support-grid">
                <% supportMap.forEach((names, offer) => { %>
                  <div class="support-offer-card">
                    <div class="offer-top">
                      <span class="offer-text"><%= offer %></span>
                      <span class="offer-count"><%= names.length %></span>
                    </div>
                    <div class="offer-givers">
                      <% names.forEach(name => { %>
                        <span class="giver-tag"><%= name %></span>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <% if (supportOthers.length > 0) { %>
              <div class="support-others-list">
                <h4 class="support-others-label">✏️ Custom offers</h4>
                <% supportOthers.forEach(sub => { %>
                  <div class="support-other-item">
                    <span class="support-other-body"><%= sub.support_other %></span>
                    <span class="giver-tag"><%= sub.submitter_name || 'Anonymous' %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        <% } %>

      <% } %>
    </section>

  </main>

  <script>
    const copyBtn = document.getElementById('copyBtn');
    if (copyBtn) {
      copyBtn.addEventListener('click', copyLink);
    }

    async function copyLink() {
      const input = document.getElementById('generatedLink');
      const btn = document.getElementById('copyBtn');
      const text = input.value;

      try {
        await navigator.clipboard.writeText(text);
      } catch (e) {
        input.focus();
        input.select();
        input.setSelectionRange(0, 99999);
        document.execCommand('copy');
      }

      btn.textContent = 'Copied! ✅';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'Copy 🌸';
        btn.classList.remove('copied');
      }, 2500);
    }
  </script>
</body>
</html>
